# ─────────────────────────────────────────────────────────────
# SPA routing — redireciona tudo que não é arquivo real para
# o index.html, para o React Router assumir o controle.
# Necessário na Hostinger (Apache) porque senão refresh em
# /learn, /flashcards, etc. retorna 404.
# ─────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Não reescreve arquivos e diretórios que existem de verdade
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Todo o resto vai para index.html
  RewriteRule ^ index.html [L]
</IfModule>

# ─────────────────────────────────────────────────────────────
# Cache longo para assets com hash no nome (Vite gera assim)
# ─────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|otf|png|jpg|jpeg|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html nunca fica em cache (senão usuário não pega deploys novos)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ─────────────────────────────────────────────────────────────
# Compressão gzip (reduz bundle em ~3x)
# ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─────────────────────────────────────────────────────────────
# Força HTTPS (depois que o SSL estiver ativo no hPanel)
# ─────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
